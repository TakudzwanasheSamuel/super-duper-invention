{
  "expo": {
    "name": "myBudget",
    "slug": "mybudget",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "mybudget",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "primaryColor": "#0B1120",
    "backgroundColor": "#0B1120",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mybudget.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "myBudget uses Face ID so only you can unlock your finances."
      }
    },
    "android": {
      "package": "com.mybudget.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0B1120",
        "foregroundImage": "./assets/images/logo.png",
        "monochromeImage": "./assets/images/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "mybudget",
              "host": "budget"
            },
            {
              "scheme": "mybudget",
              "host": "insights"
            },
            {
              "scheme": "mybudget",
              "host": "settings"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "notification": {
      "icon": "./assets/images/logo.png",
      "color": "#0B1120",
      "androidMode": "default"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#0B1120",
          "dark": {
            "backgroundColor": "#0B1120"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#0B1120",
          "defaultChannel": "default"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "SmallWidget",
              "label": "myBudget (small)",
              "description": "Shows your myBudget net balance.",
              "minWidth": "110dp",
              "minHeight": "110dp"
            },
            {
              "name": "MediumWidget",
              "label": "myBudget (medium)",
              "description": "Shows net balance, today's spending, and last transaction.",
              "minWidth": "250dp",
              "minHeight": "110dp"
            }
          ]
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
